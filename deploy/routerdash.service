[Unit]
Description=RouterDash web dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
Group=root
Environment=ROUTERDASH_ADDR=:8080
ExecStart=/usr/local/bin/routerdash
Restart=on-failure
RestartSec=5s
NoNewPrivileges=true
ProtectSystem=full
ProtectHome=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
